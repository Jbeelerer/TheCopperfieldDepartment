  messages:
  - sender: {fileID: 11400000, guid: 7bc672009af784901b761504341df47d, type: 2}
    message: Same time, same place?
    timeStamp: 05:40 PM
  - sender: {fileID: 11400000, guid: b6bfd41bc63d440f2a38a08d19d45749, type: 2}
    message: "No\u2026 marc is in the kitchen at the moment. Let\u2019s meet in the
      evening."
    timeStamp: 07:40 AM
  - sender: {fileID: 11400000, guid: b6bfd41bc63d440f2a38a08d19d45749, type: 2}
    message: "Please bring some pistacies from upstairs. We are all out down here. 
      I\u2019m starving\u2026 I had barely any leftovers from yesterday to heat up
      for lunch."
    timeStamp: 06:40 PM
  - sender: {fileID: 11400000, guid: b6bfd41bc63d440f2a38a08d19d45749, type: 2}
    message: "also bring enough warm clothing. I\u2019ts quite fresh in our office
      currently."
    timeStamp: 07:11 PM
  - sender: {fileID: 11400000, guid: b6bfd41bc63d440f2a38a08d19d45749, type: 2}
    message: Where are you?
